{
  "@odata.type": "#microsoft.graph.deviceManagementConfigurationPolicy",
  "name": "SEC-WIN-FW-IG1-DomainProfile",
  "description": "G3MIT Standard Security Baseline. Implements the CISv4 Implementation Group 1 (IG1) Windows Defender Firewall Domain Profile configuration for managed Windows endpoints. This policy consolidates Firewall Domain Profile settings into a single configuration to prevent duplicate Intune setting conflicts. The policy enables the Windows Firewall Domain Profile, blocks unsolicited inbound traffic, enables firewall logging for dropped packets and successful connections, configures the recommended firewall log size, and disables inbound notification prompts. Assign to SEC-WIN-CISIG1-STD-Dynamic and exclude SEC-WIN-CISIG1-EXC-Assigned.",
  "platforms": "windows10",
  "technologies": "mdm",
